# App URL (Auth.js / OAuth callbacks). Local: http://localhost:3000 — prod: https://knife.rip
AUTH_URL="http://localhost:3000"
# Generate: openssl rand -base64 32
AUTH_SECRET="8Xjx6UNj/ecImy7SvRS7wSy263MzDZ/2o/kI9inaEME="

# Optional: canonical site URL for Stripe redirects if AUTH_URL unset
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# PostgreSQL (e.g. Neon, Supabase, local Docker — see README)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Discord — https://discord.com/developers/applications
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
# Bot token (same application) — server-only; used to list guilds Knife is in for /dashboard
DISCORD_BOT_TOKEN=""

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# One-time Pro price — $10 USD, one-time (not recurring), in Stripe Dashboard → Products
STRIPE_PRICE_PRO_LIFETIME=""

# Optional: Plausible Analytics (https://plausible.io) — your site domain in Plausible
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# Bot ↔ site shared secret (required for command sync + premium API from the bot)
# 1) Generate once:  openssl rand -hex 32
# 2) Put the SAME string here AND in any machine that runs the Discord bot (same repo .env is fine).
# 3) Site uses it for: GET /api/internal/entitlement, POST /api/internal/commands
# 4) Bot sends: Authorization: Bearer <this value>
# 5) Start the Next site (npm run dev) before the bot so sync can reach the API.
BOT_INTERNAL_SECRET=""
# If the bot runs on another host, set the site origin (no trailing slash). Else AUTH_URL / NEXT_PUBLIC_SITE_URL is used.
SITE_API_BASE_URL=""

# Public bot invite (OAuth2 URL); leave empty until ready
NEXT_PUBLIC_DISCORD_INVITE_URL="https://discord.com/oauth2/authorize?client_id=1490131633880174603&permissions=8&integration_type=0&scope=bot"
